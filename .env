# .env
APP_ENV=dev
APP_SECRET=changeme

# Base de données générique (sera écrasée par .env.local)
DATABASE_URL="mysql://app:password@127.0.0.1:3306/dbname?serverVersion=8.0&charset=utf8mb4"

# Mailer par défaut
MAILER_DSN=null://null

# Messenger par défaut
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0