{% extends 'dashboard/admin/_base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/admin/cursus.css') }}">
{% endblock %}

{% block title %}Admin - Archiver un cursus{% endblock %}

{% block dashboard_content %}

  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Archiver un cursus</h1>
      <p class="admin-page-subtitle">
        Ce cursus ne sera plus visible côté utilisateurs.
      </p>
    </div>

    <a href="{{ path('admin_cursus_index') }}" class="btn btn-secondary">← Retour</a>
  </div>

  <div class="dashboard-card card-white admin-form-card admin-container-narrow">

    <h2 class="theme-detail-title">{{ cursus.name }}</h2>

    <p class="cursus-meta" style="margin-top: 8px;">
      <strong>Thème :</strong> {{ cursus.theme.name }}<br>
      <strong>Prix :</strong> {{ cursus.price|number_format(2, ',', ' ') }} €
    </p>

    {% if cursus.description %}
      <p class="theme-detail-desc">{{ cursus.description }}</p>
    {% endif %}

    <div class="admin-alert admin-alert-danger">
      ⚠️ Ce cursus va être archivé (désactivé).
      <strong>Les leçons et achats liés ne seront pas supprimés.</strong>
    </div>

    <form method="post"
          action="{{ path('admin_cursus_disable', { id: cursus.id }) }}"
          class="inline-form"
          onsubmit="return confirm('Confirmer l\\'archivage ?');">

      {# IMPORTANT : token dédié à l’action disable #}
      <input type="hidden" name="_token" value="{{ csrf_token('cursus_disable' ~ cursus.id) }}">

      <div class="admin-form-actions">
        <button class="btn btn-danger" type="submit">Confirmer l’archivage</button>
        <a href="{{ path('admin_cursus_index') }}" class="btn btn-secondary">Annuler</a>
      </div>

    </form>

  </div>

{% endblock %}