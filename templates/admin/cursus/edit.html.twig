{% extends 'dashboard/admin/_base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/admin/cursus.css') }}">
{% endblock %}

{% block title %}Admin - Modifier un cursus{% endblock %}

{% block dashboard_content %}

<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title">Modifier : {{ cursus.name }}</h1>
    <p class="admin-page-subtitle">
      Modifie le nom, le thème, le prix, la description et l’image.
    </p>
  </div>

  <a href="{{ path('admin_cursus_index') }}" class="btn btn-secondary">← Retour</a>
</div>

<div class="dashboard-card card-white admin-form-card admin-container-narrow">

  {{ form_start(form) }}

  <div class="admin-form-grid">
    <div class="admin-form-field--full">{{ form_row(form.name) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.theme) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.price) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.description) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.image) }}</div>
  </div>

  <div class="admin-form-actions">
    <button class="btn" type="submit">Enregistrer</button>
    <a href="{{ path('admin_cursus_index') }}" class="btn btn-secondary">Annuler</a>

    {% if cursus.isActive %}
      <a href="{{ path('admin_cursus_delete', {'id': cursus.id}) }}" class="btn btn-danger">
        Désactiver
      </a>
    {% endif %}
  </div>

  {{ form_end(form) }}

</div>

{% endblock %}