{% extends 'base.html.twig' %}

{% block title %}Admin - Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin/dashboard.css') }}">
{% endblock %}

{% block body %}
  <section class="admin-dashboard">
    <header class="admin-dashboard__header">
      <h1>Dashboard Admin</h1>
      <p>Accès rapide à la gestion de la plateforme.</p>
    </header>

    <div class="admin-dashboard__grid">
      <a class="admin-card" href="{{ path('admin_theme_index') }}">
        <h2>Thèmes</h2>
        <p>Liste / Ajouter / Modifier / Supprimer</p>
      </a>

      <a class="admin-card" href="{{ path('admin_cursus_index') }}">
        <h2>Cursus</h2>
        <p>Liste / Ajouter / Modifier / Supprimer</p>
      </a>

      <a class="admin-card" href="{{ path('admin_lesson_index') }}">
        <h2>Leçons</h2>
        <p>Liste / Ajouter / Modifier / Supprimer</p>
      </a>

      <a class="admin-card" href="{{ path('admin_purchase_index') }}">
        <h2>Purchases</h2>
        <p>Historique des achats</p>
      </a>

      <a class="admin-card" href="{{ path('admin_contact_index') }}">
        <h2>Messages</h2>
        <p>Voir / Trier / Marquer traité</p>
      </a>
    </div>
  </section>
{% endblock %}