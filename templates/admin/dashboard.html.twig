{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Dashboard{% endblock %}

{# Pages privées #}
{% block robots %}noindex,nofollow{% endblock %}

{% block dashboard_content %}

  {% if app.user %}
    <h1>Bienvenue, {{ app.user.firstName }} {{ app.user.lastName }} !</h1>
  {% else %}
    <h1>Bienvenue</h1>
  {% endif %}

  <div class="dashboard-cards">

    {# Utilisateurs #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_users_index', { status: 'active' }) }}"
      role="link"
      tabindex="0"
      aria-label="Accéder aux utilisateurs"
    >
      <div class="card-head">
        <h2>Gestion des utilisateurs</h2>
      </div>

      <div class="card-links">
        <a href="{{ path('admin_users_index', { status: 'active' }) }}" data-no-card-click>
          Liste des utilisateurs actifs
        </a>

        <a href="{{ path('admin_users_index', { action: 'edit', status: 'active' }) }}" data-no-card-click>
          Comptes & suivi pédagogique
        </a>
      </div>

      <a
        href="{{ path('admin_users_index', { status: 'active' }) }}"
        class="card-link-indicator"
        data-no-card-click
      >
        Accéder <span aria-hidden="true">→</span>
      </a>
    </div>

    {# Thèmes pédagogiques #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_theme_index') }}"
      role="link"
      tabindex="0"
      aria-label="Accéder aux thèmes pédagogiques"
    >
      <h2>Thèmes pédagogiques</h2>

      <div class="card-links">
        <a href="{{ path('admin_theme_index') }}" data-no-card-click>Liste des thèmes</a>
        <a href="{{ path('admin_theme_new') }}" data-no-card-click>Créer un nouveau thème</a>
      </div>

      <a href="{{ path('admin_theme_index') }}" class="card-link-indicator" data-no-card-click>
        Accéder <span aria-hidden="true">→</span>
      </a>
    </div>

    {# Cursus #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_cursus_index') }}"
      role="link"
      tabindex="0"
      aria-label="Accéder aux cursus"
    >
      <h2>Cursus</h2>

      <div class="card-links">
        <a href="{{ path('admin_cursus_index') }}" data-no-card-click>Liste des cursus</a>
        <a href="{{ path('admin_cursus_new') }}" data-no-card-click>Créer un nouveau cursus</a>
      </div>

      <a href="{{ path('admin_cursus_index') }}" class="card-link-indicator" data-no-card-click>
        Accéder <span aria-hidden="true">→</span>
      </a>
    </div>

    {# Leçons #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_lesson_index') }}"
      role="link"
      tabindex="0"
      aria-label="Accéder aux leçons"
    >
      <div class="card-head">
        <h2>Leçons</h2>
      </div>

      <div class="card-links">
        <a href="{{ path('admin_lesson_index') }}" data-no-card-click>Catalogue des leçons</a>
        <a href="{{ path('admin_lesson_new') }}" data-no-card-click>Ajouter une leçon</a>
      </div>

      <a href="{{ path('admin_lesson_index') }}" class="card-link-indicator" data-no-card-click>
        Accéder <span aria-hidden="true">→</span>
      </a>
    </div>

    {# Commandes & paiements #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_purchase_index') }}"
      role="link"
      tabindex="0"
      aria-label="Accéder aux commandes et paiements"
    >
      <h2>Commandes & paiements</h2>

      <div class="card-links">
        <a href="{{ path('admin_purchase_index') }}" data-no-card-click>Toutes les commandes</a>
        <a href="{{ path('admin_purchase_index', { status: 'paid' }) }}" data-no-card-click>Commandes payées</a>
        <a href="{{ path('admin_purchase_index', { status: 'pending' }) }}" data-no-card-click>Paiements en attente</a>
        <a href="{{ path('admin_purchase_index', { status: 'canceled' }) }}" data-no-card-click>Commandes annulées</a>
      </div>

      <a href="{{ path('admin_purchase_index') }}" class="card-link-indicator" data-no-card-click>
        Accéder <span aria-hidden="true">→</span>
      </a>
    </div>

    {# Messagerie contact #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_contact_index') }}"
      role="link"
      tabindex="0"
      aria-label="Accéder à la messagerie"
    >
      <h2>Messagerie</h2>

      <div class="card-links">
        <a href="{{ path('admin_contact_index') }}" data-no-card-click>Tous les messages</a>
        <a href="{{ path('admin_contact_index', { status: 'read' }) }}" data-no-card-click>Messages lus</a>
        <a href="{{ path('admin_contact_index', { status: 'unread' }) }}" data-no-card-click>Messages non lus</a>
        <a href="{{ path('admin_contact_index', { status: 'handled' }) }}" data-no-card-click>Messages traités</a>
      </div>

      <a href="{{ path('admin_contact_index') }}" class="card-link-indicator" data-no-card-click>
        Accéder <span aria-hidden="true">→</span>
      </a>
    </div>

  </div>

{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    document
      .querySelectorAll('.dashboard-card-clickable[data-href]')
      .forEach((card) => {
        const href = card.dataset.href;

        card.addEventListener('click', (e) => {
          if (e.target.closest('a, button, [data-no-card-click]')) return;
          window.location.href = href;
        });

        card.addEventListener('keydown', (e) => {
          if (e.target.closest('a, button, [data-no-card-click]')) return;

          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            window.location.href = href;
          }
        });
      });
  </script>
{% endblock %}