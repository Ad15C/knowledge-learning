{# templates/admin/dashboard.html.twig #}
{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Dashboard{% endblock %}

{% block dashboard_content %}

  {% if app.user %}
    <h1>Bienvenue, {{ app.user.firstName }} {{ app.user.lastName }} !</h1>
  {% else %}
    <h1>Bienvenue</h1>
  {% endif %}

  <div class="dashboard-cards">

    {# ===================== CLIENTS ===================== #}
    <div class="dashboard-card dashboard-card-clickable">
      <h2>Clients</h2>

      <div class="card-links">
        <a href="{{ path('admin_users_index') }}">Voir tous les clients</a>
        <a href="{{ path('admin_users_index', { action: 'edit' }) }}">Mettre à jour un profil</a>
        <a href="{{ path('admin_users_index', { action: 'delete' }) }}">Désactiver un profil</a>
      </div>

      <a href="{{ path('admin_users_index') }}" class="card-link-indicator">
        Gérer →
      </a>
    </div>


    {# ===================== THEMES ===================== #}
    <div class="dashboard-card dashboard-card-clickable">
      <h2>Thèmes</h2>

      <div class="card-links">
        <a href="{{ path('admin_theme_index') }}">Voir tous les thèmes</a>
        <a href="{{ path('admin_theme_index') }}">Créer un thème</a>
        <a href="{{ path('admin_theme_index') }}">Modifier un thème</a>
        <a href="{{ path('admin_theme_index') }}">Supprimer un thème</a>
      </div>

      <a href="{{ path('admin_theme_index') }}" class="card-link-indicator">
        Gérer →
      </a>
    </div>


    {# ===================== CURSUS ===================== #}
    <div class="dashboard-card dashboard-card-clickable">
      <h2>Cursus</h2>

      <div class="card-links">
        <a href="{{ path('admin_cursus_index') }}">Voir tous les cursus</a>
        <a href="{{ path('admin_cursus_index') }}">Créer un cursus</a>
        <a href="{{ path('admin_cursus_index') }}">Modifier un cursus</a>
        <a href="{{ path('admin_cursus_index') }}">Supprimer un cursus</a>
      </div>

      <a href="{{ path('admin_cursus_index') }}" class="card-link-indicator">
        Gérer →
      </a>
    </div>


    {# ===================== LEÇONS ===================== #}
    <div class="dashboard-card dashboard-card-clickable">
      <h2>Leçons</h2>

      <div class="card-links">
        <a href="{{ path('admin_lesson_index') }}">Voir toutes les leçons</a>
        <a href="{{ path('admin_lesson_index') }}">Créer une leçon</a>
        <a href="{{ path('admin_lesson_index') }}">Modifier une leçon</a>
        <a href="{{ path('admin_lesson_index') }}">Supprimer une leçon</a>
      </div>

      <a href="{{ path('admin_lesson_index') }}" class="card-link-indicator">
        Gérer →
      </a>
    </div>


    {# ===================== COMMANDES ===================== #}
    <div class="dashboard-card dashboard-card-clickable">
      <h2>Commandes</h2>

      <div class="card-links">
        <a href="{{ path('admin_purchase_index') }}">Voir les commandes</a>
        <a href="{{ path('admin_purchase_index') }}">Voir le détail d'une commande</a>
      </div>

      <a href="{{ path('admin_purchase_index') }}" class="card-link-indicator">
        Voir →
      </a>
    </div>


    {# ===================== MESSAGES ===================== #}
    <div class="dashboard-card dashboard-card-clickable">
      <h2>Messages</h2>

      <div class="card-links">
        <a href="{{ path('admin_contact_index') }}">Tous les messages</a>
        <a href="{{ path('admin_contact_unhandled') }}">Messages non traités</a>
        <a href="{{ path('admin_contact_handled') }}">Messages traités</a>
      </div>

      <a href="{{ path('admin_contact_index') }}" class="card-link-indicator">
        Voir →
      </a>
    </div>

  </div>

{% endblock %}