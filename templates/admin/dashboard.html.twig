{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Dashboard{% endblock %}

{% block dashboard_content %}

  {% if app.user %}
    <h1>Bienvenue, {{ app.user.firstName }} {{ app.user.lastName }} !</h1>
  {% else %}
    <h1>Bienvenue</h1>
  {% endif %}

  <div class="dashboard-cards">
    {# Clients #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_users_index', { status: 'active' }) }}"
      role="link"
      tabindex="0"
      aria-label="Gérer les clients"
    >
      <div class="card-head">
        <h2>Clients</h2>
      </div>

      <div class="card-links">
        <span>Mettre à jour, archiver, restaurer depuis la liste</span>
      </div>

      <a
        href="{{ path('admin_users_index', { status: 'active' }) }}"
        class="card-link-indicator"
        data-no-card-click
      >
        Gérer <span aria-hidden="true">→</span>
      </a>
    </div>

    {# Thèmes #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_theme_index') }}"
      role="link"
      tabindex="0"
      aria-label="Gérer les thèmes"
    >
      <h2>Thèmes</h2>
      <div class="card-links">
        <a href="{{ path('admin_theme_index') }}" data-no-card-click>Gérer les thèmes</a>
        <a href="{{ path('admin_theme_new') }}" data-no-card-click>Créer un thème</a>
      </div>
      <a href="{{ path('admin_theme_index') }}" class="card-link-indicator" data-no-card-click>Gérer →</a>
    </div>

    {# Cursus #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_cursus_index') }}"
      role="link"
      tabindex="0"
      aria-label="Gérer les cursus"
    >
      <h2>Cursus</h2>
      <div class="card-links">
        <a href="{{ path('admin_cursus_index') }}" data-no-card-click>Gérer les cursus</a>
        <a href="{{ path('admin_cursus_new') }}" data-no-card-click>Créer un cursus</a>
      </div>
      <a href="{{ path('admin_cursus_index') }}" class="card-link-indicator" data-no-card-click>Gérer →</a>
    </div>

    {# Leçons #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_lesson_index') }}"
      role="link"
      tabindex="0"
      aria-label="Gérer les leçons"
    >
      <div class="card-head">
        <h2>Leçons</h2>
      </div>

      <div class="card-links">
        <a href="{{ path('admin_lesson_index') }}" data-no-card-click>
          Voir toutes les leçons
        </a>

        <a href="{{ path('admin_lesson_index') }}" data-no-card-click>
          Créer une leçon
        </a>
      </div>
      <a href="{{ path('admin_lesson_index') }}" class="card-link-indicator" data-no-card-click>Gérer →</a>
    </div>

    {# Commandes #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_purchase_index') }}"
      role="link"
      tabindex="0"
      aria-label="Voir les commandes"
    >
      <h2>Commandes</h2>
      <div class="card-links">
        <a href="{{ path('admin_purchase_index') }}" data-no-card-click>Voir les commandes</a>
      </div>
      <a href="{{ path('admin_purchase_index') }}" class="card-link-indicator" data-no-card-click>Gérer →</a>
    </div>

    {# Messages Contact #}
    <div
      class="dashboard-card dashboard-card-clickable"
      data-href="{{ path('admin_contact_index') }}"
      role="link"
      tabindex="0"
      aria-label="Voir les messages"
    >
      <h2>Messages</h2>
      <div class="card-links">
        <a href="{{ path('admin_contact_index') }}" data-no-card-click>Tous les messages</a>
        <a href="{{ path('admin_contact_index') }}" data-no-card-click>Non traités</a>
        <a href="{{ path('admin_contact_index') }}" data-no-card-click>Traités</a>
      </div>
      <a href="{{ path('admin_contact_index') }}" class="card-link-indicator" data-no-card-click>Gérer →</a>
    </div>

  </div>

<script>
  document.querySelectorAll('.dashboard-card-clickable[data-href]').forEach((card) => {
    const href = card.dataset.href;

    card.addEventListener('click', (e) => {
      if (e.target.closest('a, button, [data-no-card-click]')) return;
      window.location.href = href;
    });

    card.addEventListener('keydown', (e) => {
      if (e.target.closest('a, button, [data-no-card-click]')) return;
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        window.location.href = href;
      }
    });
  });
</script>
{% endblock %}