{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Désactiver une leçon{% endblock %}

{% block dashboard_content %}

  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Désactiver la leçon</h1>
      <p class="admin-page-subtitle">
        Vous êtes sur le point de désactiver cette leçon.
      </p>
    </div>

    <a href="{{ path('admin_lesson_index') }}" class="btn btn-secondary">← Retour</a>
  </div>

  <div class="dashboard-card card-white admin-form-card admin-container-narrow">
    <h2 class="lesson-detail-title">{{ lesson.title }}</h2>

    <p class="lesson-meta" style="margin-top: 8px;">
      <strong>Cursus :</strong> {{ lesson.cursus ? lesson.cursus.name : '—' }}<br>
      <strong>Prix :</strong>
      {{ lesson.price is not null ? (lesson.price|number_format(2, ',', ' ') ~ ' €') : '—' }}
    </p>

    <div class="admin-alert admin-alert-danger">
      Elle ne sera plus visible par les utilisateurs, mais les achats liés ne seront pas supprimés.
      <br>Êtes-vous sûr de vouloir continuer ?
    </div>

    <form
      method="post"
      action="{{ path('admin_lesson_disable', { slug: lesson.slug }) }}"
      class="inline-form"
      onsubmit="return confirm('Confirmer la désactivation ?');"
    >
      <input type="hidden" name="_token" value="{{ csrf_token('lesson_disable' ~ lesson.id) }}">

      <div class="admin-form-actions">
        <button class="btn btn-danger" type="submit">Confirmer la désactivation</button>
        <a href="{{ path('admin_lesson_index') }}" class="btn btn-secondary">Annuler</a>
      </div>
    </form>
  </div>

{% endblock %}