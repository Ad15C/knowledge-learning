{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Leçons{% endblock %}

{% block dashboard_content %}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title">Gestion des leçons</h1>
        <p class="admin-page-subtitle">
            Dans cette section, vous pouvez créer, modifier, activer ou désactiver des leçons.
        </p>
    </div>

    <a href="{{ path('admin_lesson_new') }}" class="btn">
        + Créer une leçon
    </a>
</div>

<form method="get" class="admin-filters">
    <div class="admin-filters-row">

        <input type="search"
               name="q"
               value="{{ filters.q ?? '' }}"
               placeholder="Rechercher une leçon…"
               class="admin-filter-input">

        <select name="theme" class="admin-filter-select">
            <option value="">Tous les thèmes</option>
            {% for theme in themes %}
                <option value="{{ theme.id }}"
                    {{ (filters.theme ?? null) == theme.id ? 'selected' : '' }}>
                    {{ theme.name }}
                </option>
            {% endfor %}
        </select>

        <select name="cursus" class="admin-filter-select">
            <option value="">Tous les cursus</option>
            {% for c in cursus_list %}
                <option value="{{ c.id }}"
                    {{ (filters.cursus ?? null) == c.id ? 'selected' : '' }}>
                    {{ c.name }}
                </option>
            {% endfor %}
        </select>

        <select name="status" class="admin-filter-select">
            <option value="all"
                {{ (filters.status ?? 'all') == 'all' ? 'selected' : '' }}>
                Toutes
            </option>
            <option value="active"
                {{ (filters.status ?? 'all') == 'active' ? 'selected' : '' }}>
                Actives
            </option>
            <option value="archived"
                {{ (filters.status ?? 'all') == 'archived' ? 'selected' : '' }}>
                Archivées
            </option>
        </select>

        <select name="sort" class="admin-filter-select">
            <option value="id_desc"
                {{ (filters.sort ?? 'id_desc') == 'id_desc' ? 'selected' : '' }}>
                Plus récents
            </option>
            <option value="title_asc"
                {{ (filters.sort ?? '') == 'title_asc' ? 'selected' : '' }}>
                Titre A → Z
            </option>
            <option value="title_desc"
                {{ (filters.sort ?? '') == 'title_desc' ? 'selected' : '' }}>
                Titre Z → A
            </option>
            <option value="price_asc"
                {{ (filters.sort ?? '') == 'price_asc' ? 'selected' : '' }}>
                Prix croissant
            </option>
            <option value="price_desc"
                {{ (filters.sort ?? '') == 'price_desc' ? 'selected' : '' }}>
                Prix décroissant
            </option>
        </select>

        <button class="btn" type="submit">Filtrer</button>
        <a class="btn btn-secondary" href="{{ path('admin_lesson_index') }}">
            Réinitialiser
        </a>

    </div>
</form>

<div class="lesson-grid">

    {% for lesson in lessons %}
        <div class="lesson-card">

            {% if lesson.image %}
                {% set img = lesson.image %}
                <img src="{{ img starts with 'http' ? img : asset(img) }}"
                     alt="{{ lesson.title }}"
                     class="lesson-image"
                     loading="lazy">
            {% endif %}

            <h2 class="lesson-title">
                <span>{{ lesson.title }}</span>

                {% if lesson.isActive %}
                    <span class="badge badge-active">Active</span>
                {% else %}
                    <span class="badge badge-archived">Inactive</span>
                {% endif %}
            </h2>

            <p class="lesson-meta">
                <strong>Cursus :</strong>
                {{ lesson.cursus ? lesson.cursus.name : '—' }}<br>

                <strong>Prix :</strong>
                {{ lesson.price is not null
                    ? (lesson.price|number_format(2, ',', ' ') ~ ' €')
                    : '—' }}

                {% if lesson.videoUrl %}
                    <br><strong>Vidéo :</strong>
                    <span class="muted">oui</span>
                {% endif %}
            </p>

            {% if lesson.fiche %}
                {% set ficheText = lesson.fiche|striptags|trim %}
                <p class="lesson-desc">
                    {{ ficheText|length > 160
                        ? ficheText|slice(0, 160) ~ '…'
                        : ficheText }}
                </p>
            {% endif %}

            <div class="admin-actions">

                <a href="{{ path('admin_lesson_edit', {'id': lesson.id}) }}"
                   class="btn btn-secondary">
                    Modifier
                </a>

                {% if lesson.isActive %}
                    <a href="{{ path('admin_lesson_delete', {'id': lesson.id}) }}"
                       class="btn btn-warning">
                        Désactiver
                    </a>
                {% else %}
                    <form method="post"
                          action="{{ path('admin_lesson_activate', {'id': lesson.id}) }}"
                          class="inline-form">

                        <input type="hidden"
                               name="_token"
                               value="{{ csrf_token('lesson_activate' ~ lesson.id) }}">

                        <button class="btn btn-restore" type="submit">
                            Activer
                        </button>
                    </form>
                {% endif %}

            </div>

        </div>
    {% else %}
        <p>Aucune leçon pour le moment.</p>
    {% endfor %}

</div>

<a href="{{ path('admin_dashboard') }}" class="back-link">
    ← Retour à l'espace administrateur
</a>

{% endblock %}