{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Nouvelle leçon{% endblock %}

{% block dashboard_content %}

<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title">Créer une leçon</h1>
    <p class="admin-page-subtitle">Titre, cursus, prix, fiche, vidéo, image.</p>
  </div>

  <a href="{{ path('admin_lesson_index') }}" class="btn btn-secondary">← Retour</a>
</div>

<div class="dashboard-card card-white admin-form-card admin-container-narrow">

  {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
  {{ form_errors(form) }}

  <div class="admin-form-grid">
    <div class="admin-form-field--full">{{ form_row(form.title) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.cursus) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.price) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.fiche) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.videoUrl) }}</div>
    <div class="admin-form-field--full">{{ form_row(form.image) }}</div>
  </div>

  <div class="admin-form-actions">
    <button class="btn" type="submit">Créer</button>
    <a href="{{ path('admin_lesson_index') }}" class="btn btn-secondary">Annuler</a>
  </div>

  {{ form_end(form) }}

</div>

{% endblock %}
