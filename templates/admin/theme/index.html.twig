{% extends 'dashboard/admin/_base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/admin/theme.css') }}">
{% endblock %}

{% block title %}Admin - Thèmes{% endblock %}

{% block dashboard_content %}

<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title">Thèmes</h1>
    <p class="admin-page-subtitle">Créer, modifier, désactiver / réactiver des thèmes.</p>
  </div>

  <a href="{{ path('admin_theme_new') }}" class="btn">+ Créer un thème</a>
</div>

<div class="themes-grid">
  {% for theme in themes %}
    <div class="theme-card">

      {% if theme.image %}
        <img src="{{ asset(theme.image) }}" alt="{{ theme.name }}" class="theme-image">
      {% endif %}

      <h2>
        <span>{{ theme.name }}</span>

        {% if theme.isActive %}
          <span class="badge badge-active">Actif</span>
        {% else %}
          <span class="badge badge-archived">Inactif</span>
        {% endif %}
      </h2>

      {% if theme.description %}
        <p>{{ theme.description }}</p>
      {% endif %}

      <div class="admin-actions">
        <a href="{{ path('admin_theme_edit', {'id': theme.id}) }}" class="btn btn-secondary">Modifier</a>

        {% if theme.isActive %}
          <a href="{{ path('admin_theme_delete', {'id': theme.id}) }}" class="btn btn-danger">Désactiver</a>
        {% else %}
          <form method="post" action="{{ path('admin_theme_activate', {'id': theme.id}) }}" class="inline-form">
            <input type="hidden" name="_token" value="{{ csrf_token('theme_activate_' ~ theme.id) }}">
            <button class="btn" type="submit">Réactiver</button>
          </form>
        {% endif %}
      </div>

    </div>
  {% else %}
    <p>Aucun thème pour le moment.</p>
  {% endfor %}
</div>

{% endblock %}