{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Nouveau thème{% endblock %}

{% block dashboard_content %}

  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Créer un thème</h1>
      <p class="admin-page-subtitle">Vous pouvez créer un nouveau thème en complétant les champs requis (nom, description, image).</p>
    </div>

    <a href="{{ path('admin_theme_index') }}" class="btn btn-secondary">← Retour à la liste des thèmes</a>
  </div>

  <div class="dashboard-card card-white admin-form-card admin-container-narrow">
    {{ form_start(form) }}

      <div class="admin-form-grid">
        <div class="admin-form-field--full">
          {{ form_label(form.name) }}
          {{ form_widget(form.name) }}
          {{ form_errors(form.name) }}
        </div>

        <div class="admin-form-field--full">
          {{ form_label(form.description) }}
          {{ form_widget(form.description) }}
          {{ form_errors(form.description) }}
        </div>

        <div class="admin-form-field--full">
          {{ form_label(form.image) }}
          {{ form_widget(form.image) }}
          {{ form_errors(form.image) }}
        </div>
      </div>

      <div class="admin-form-actions">
        <button class="btn" type="submit">Créer</button>
        <a href="{{ path('admin_theme_index') }}" class="btn btn-secondary">Annuler</a>
      </div>

    {{ form_end(form) }}
  </div>

{% endblock %}