{% extends 'dashboard/admin/_base.html.twig' %}

{% block title %}Admin - Utilisateurs{% endblock %}

{% block robots %}noindex,nofollow{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/admin/users.css') }}">
{% endblock %}

{% block dashboard_content %}

  <div class="admin-page-header admin-page-header--list">
    <div>
      <h1 class="admin-page-title admin-page-title--list">Gestion des utilisateurs</h1>
      <p class="admin-page-subtitle">
          Dans cette section, vous pouvez consulter et gérer les comptes utilisateurs,
          en modifiant leurs informations, leurs rôles et leur statut (activation ou désactivation).
        </p>
      <p class="admin-page-subtitle admin-page-subtitle--list">
        {{ total }} utilisateur(s) • Page {{ page }}/{{ pages }}
      </p>
    </div>
  </div>

  {% set mode = action|default('') %}

  {# ======= Modes ======= #}
  <div class="admin-actions admin-actions--modes">
    <a href="{{ path('admin_users_index', { status: status }) }}"
       class="btn btn-secondary">
      Mode standard
    </a>

    <a href="{{ path('admin_users_index', { action: 'edit', status: status }) }}"
       class="btn btn-secondary">
      Mode modification
    </a>

    <a href="{{ path('admin_users_index', { action: 'delete', status: status }) }}"
       class="btn btn-secondary">
      Mode désactivation
    </a>
  </div>

  {# ======= Onglets statut ======= #}
  {% set baseParams = { action: mode, q: q, sort: sort, dir: dir } %}
  <div class="admin-actions admin-actions--tabs">
    <a href="{{ path('admin_users_index', baseParams|merge({ status: 'active', page: 1 })) }}"
       class="btn {{ status == 'active' ? '' : 'btn-secondary' }}">
      Actifs
    </a>

    <a href="{{ path('admin_users_index', baseParams|merge({ status: 'archived', page: 1 })) }}"
       class="btn {{ status == 'archived' ? '' : 'btn-secondary' }}">
      Archivés
    </a>

    <a href="{{ path('admin_users_index', baseParams|merge({ status: 'all', page: 1 })) }}"
       class="btn {{ status == 'all' ? '' : 'btn-secondary' }}">
      Tous
    </a>
  </div>

  {# ======= Filtres ======= #}
  <form method="get" class="dashboard-filters">
    <input type="hidden" name="action" value="{{ mode }}">
    <input type="hidden" name="status" value="{{ status }}">
    <input type="hidden" name="page" value="1">

    <label for="q">Recherche :</label>
    <input type="text" id="q" name="q" value="{{ q }}" placeholder="Nom, prénom ou email">

    <label for="sort">Tri :</label>
    <select name="sort" id="sort">
      <option value="name" {{ sort == 'name' ? 'selected' : '' }}>Alphabétique</option>
      <option value="recent" {{ sort == 'recent' ? 'selected' : '' }}>Inscrits plus récents</option>
    </select>

    <label for="dir">Direction :</label>
    <select name="dir" id="dir">
      <option value="ASC" {{ dir == 'ASC' ? 'selected' : '' }}>ASC</option>
      <option value="DESC" {{ dir == 'DESC' ? 'selected' : '' }}>DESC</option>
    </select>

    <button type="submit" class="btn">Filtrer</button>

    <a href="{{ path('admin_users_index', { action: mode, status: status }) }}"
       class="btn btn-secondary">
      Réinitialiser
    </a>
  </form>

  {% if mode == 'delete' and status == 'active' %}
    <div class="admin-alert admin-alert--spaced">
      Mode désactivation : passe sur l’onglet <strong>Archivés</strong> pour voir les comptes à restaurer.
    </div>
  {% endif %}

  {% if users is empty %}
    <p>Aucun utilisateur trouvé.</p>
  {% else %}
    <div class="dashboard-card card-white admin-table-card">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Utilisateur</th>
            <th>Email</th>
            <th>Inscription</th>
            <th>Statut</th>
            <th class="admin-col-actions">Actions</th>
          </tr>
        </thead>

        <tbody>
        {% for user in users %}
          {% set isSelf = app.user and app.user.id == user.id %}

          <tr>
            <td>
              <div class="admin-user-cell">
                <strong>{{ user.lastName }} {{ user.firstName }}</strong>
                <small>#{{ user.id }}</small>
              </div>
            </td>

            <td>{{ user.email }}</td>

            <td>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '—' }}</td>

            <td>
              {% if user.archivedAt %}
                <span class="badge badge-archived">Archivé</span>
              {% else %}
                <span class="badge badge-active">Actif</span>
              {% endif %}

              {% if 'ROLE_ADMIN' in user.roles %}
                <span class="badge badge-admin">Admin</span>
              {% endif %}

              {% if not user.verified %}
                <span class="badge badge-unverified">Non vérifié</span>
              {% endif %}
            </td>

            <td class="admin-actions-cell">
              <div class="admin-actions-inline">

                {% if mode in ['', 'edit'] %}
                  <a href="{{ path('admin_users_edit', { id: user.id, status: status }) }}"
                     class="btn">
                    Gérer
                  </a>
                {% endif %}

                <a href="{{ path('admin_users_show', { id: user.id }) }}"
                   class="btn btn-secondary">
                  Fiche
                </a>

                {% if mode in ['', 'delete'] %}
                  {% if isSelf and mode == 'delete' %}
                    <span class="badge badge-admin">Toi-même</span>
                  {% elseif not isSelf %}
                    {% if user.archivedAt %}
                      <form method="post" action="{{ path('admin_users_restore', { id: user.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('restore_user_' ~ user.id) }}">
                        <button type="submit" class="btn"
                                onclick="return confirm('Confirmer la restauration de cet utilisateur ?');">
                          Restaurer
                        </button>
                      </form>
                    {% else %}
                      <form method="post" action="{{ path('admin_users_delete', { id: user.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('archive_user_' ~ user.id) }}">
                        <button type="submit" class="btn btn-danger"
                                onclick="return confirm('Confirmer l\\'archivage de cet utilisateur ?');">
                          Archiver
                        </button>
                      </form>
                    {% endif %}
                  {% endif %}
                {% endif %}

              </div>
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>

    {# ======= Pagination ======= #}
    {% if pages > 1 %}
      {% set params = { action: mode, status: status, q: q, sort: sort, dir: dir } %}
      <div class="admin-pagination">
        <a class="btn btn-secondary {{ page <= 1 ? 'is-disabled' : '' }}"
           href="{{ path('admin_users_index', params|merge({ page: page - 1 })) }}">
          ← Précédent
        </a>

        <span class="admin-pagination__label">Page {{ page }} / {{ pages }}</span>

        <a class="btn btn-secondary {{ page >= pages ? 'is-disabled' : '' }}"
           href="{{ path('admin_users_index', params|merge({ page: page + 1 })) }}">
          Suivant →
        </a>
      </div>
    {% endif %}
  {% endif %}

  <a href="{{ path('admin_dashboard') }}" class="back-link">← Retour à l'espace administrateur</a>

{% endblock %}