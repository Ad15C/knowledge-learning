<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Plateforme Knowledge Learning{% endblock %}</title>

    <!-- Favicon -->
    <link rel="icon" href="{{ asset('images/knowledge_learning_favicon.png') }}" type="image/x-icon">

    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/form.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
</head>

<body>
    {# Flash messages flottants #}
    <div class="flash-messages">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- =======================
         Header
    ====================== -->
    <header class="main-header">

    <div class="logo">
        <a href="{{ path('homepage') }}">
            <img src="{{ asset('images/knowledge_learning_logo.jpeg') }}">
        </a>
    </div>

    <div class="menu-toggle" onclick="toggleMenu()">☰</div>

    <nav class="main-nav">

        <ul>

            <li>
                <a href="{{ path('homepage') }}"
                   class="{{ app.request.attributes.get('_route') == 'homepage' ? 'active' : '' }}">
                   Accueil
                </a>
            </li>

            <li>
                <a href="#">Thèmes</a>
            </li>

            <li>
                <a href="#">Panier</a>
            </li>

            <li>
                <a href="#">Contact</a>
            </li>

            {% if app.user %}

                {% if is_granted('ROLE_ADMIN') %}

                    <li>
                        <a href="#" class="has-submenu">
                            Admin
                        </a>

                        <ul>

                            <li><a href="#">>Dashboard</a></li>

                            <li><a href="#">Utilisateurs</a></li>

                            <li><a href="#">Thèmes</a></li>

                            <li><a href="#">Cursus</a></li>

                            <li><a href="#">Leçons</a></li>

                            <li><a href="#">Achats</a></li>

                            <li><a href="#">Certifications</a></li>

                        </ul>

                    </li>

                {% else %}

                    <li>

                        <a href="{{ path('user_dashboard') }}"
                           class="has-submenu {{ app.request.attributes.get('_route') starts with 'user_dashboard' ? 'active' : '' }}">
                           Dashboard
                        </a>

                        <ul>

                            <li>
                                <a href="{{ path('user_dashboard') }}">
                                    Vue d'ensemble
                                </a>
                            </li>

                            <li>
                                <a href="{{ path('user_dashboard_edit') }}">
                                    Modifier profil
                                </a>
                            </li>

                            <li>
                                <a href="{{ path('user_dashboard_password') }}">
                                    Mot de passe
                                </a>
                            </li>

                            <li>
                                <a href="{{ path('user_dashboard_purchases') }}">
                                    Mes achats
                                </a>
                            </li>

                            <li>
                                <a href="{{ path('user_dashboard_certifications') }}">
                                    Certifications
                                </a>
                            </li>

                        </ul>

                    </li>

                {% endif %}

                <li>
                    <a href="{{ path('app_logout') }}">
                        Déconnexion
                    </a>
                </li>

            {% else %}

                <li>
                    <a href="{{ path('app_login') }}">
                        Connexion
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_register') }}">
                        Inscription
                    </a>
                </li>

            {% endif %}

        </ul>

    </nav>

</header>


    <!-- =======================
         Main Content
    ====================== -->
    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- =======================
         Footer
    ====================== -->
    <footer>
        &copy; {{ "now"|date("Y") }} Knowledge Learning - Tous droits réservés
    </footer>

    {# =======================
       JS pour menu et flashs
    ======================= #}
    <script>
        // Toggle menu mobile
        function toggleMenu() {
            const nav = document.querySelector('.main-nav ul');
            nav.classList.toggle('show');
        }

        // Sous-menus mobile
        document.querySelectorAll('.has-submenu').forEach(item => {
            item.addEventListener('click', (e) => {
                if (window.innerWidth <= 768) {
                    e.preventDefault();
                    item.parentElement.classList.toggle('open');
                }
            });
        });

        // Supprimer les flash messages après 4s
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                document.querySelectorAll('.flash').forEach(flash => flash.remove());
            }, 4000);
        });
    </script>

    {% block javascripts %}{% endblock %}

</body>
</html>
