<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Plateforme Knowledge Learning{% endblock %}</title>

    <!-- Favicon -->
    <link rel="icon" href="{{ asset('images/knowledge_learning_favicon.png') }}" type="image/x-icon">

    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body>

    <!-- =======================
         Header
    ====================== -->
    <header class="main-header">
        <!-- Logo -->
        <div class="logo">
            <a href="#"><img src="{{ asset('images/knowledge_learning_logo.jpeg') }}" alt="Knowledge Learning Logo"></a>
        </div>

        <!-- Menu -->
<nav class="main-nav">
        <ul>
            <li><a href="{{ path('homepage') }}" class="active">Accueil</a></li>
            <li><a href="#">Thèmes</a></li>
            <li><a href="#">Panier</a></li>
            <li><a href="#">Contact</a></li>

            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    <!-- Menu Admin avec sous-menu -->
                    <li>
                        <a href="#">Admin</a>
                        <ul>
                            <li><a href="#">Utilisateurs</a></li>
                            <li><a href="#">Thèmes</a></li>
                            <li><a href="#">Cursus</a></li>
                            <li><a href="#">Leçons</a></li>
                            <li><a href="#">Achats</a></li>
                            <li><a href="#">Certifications</a></li>
                            <li><a href="#">Contact</a></li>
                        </ul>
                    </li>
                {% else %}
                    <!-- Menu User avec sous-menu -->
                    <li>
                        <a href="#">Dashboard</a>
                        <ul>
                            <li><a href="#">Mon Profil</a></li>
                            <li><a href="#">Mes Achats</a></li>
                            <li><a href="#">Mes Certifications</a></li>
                        </ul>
                    </li>
                {% endif %}

                <li><a href="#">Déconnexion</a></li>
            {% else %}
                <!-- Menu Public -->
                <li><a href="#">Connexion</a></li>
                <li><a href="#">Inscription</a></li>
            {% endif %}
        </ul>
    </nav>

    </header>

    <!-- =======================
         Main Content
    ====================== -->
    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- =======================
         Footer
    ====================== -->
    <footer>
        &copy; {{ "now"|date("Y") }} Knowledge Learning - Tous droits réservés
    </footer>

</body>
</html>
