{% import 'macros.html.twig' as macros %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Plateforme Knowledge Learning{% endblock %}</title>
    <link rel="icon" href="{{ asset('images/knowledge_learning_favicon.png') }}" type="image/x-icon">

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/cart-success') }}">
        <link rel="stylesheet" href="{{ asset('styles/cart.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/certification-common') }}">
        <link rel="stylesheet" href="{{ asset('styles/certification-show') }}">
        <link rel="stylesheet" href="{{ asset('styles/certification.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/contact.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/form.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/lesson_validated.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/lesson.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/themes.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/admin/dashboard.css') }}">
    {% endblock %}
</head>
<body>

{% set cartCount = cartCount|default(0) %}

{# Flash messages #}
<div class="flash-messages">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
</div>

{# Header / Menu #}
<header class="main-header">
    <div class="logo">
        <a href="{{ path('homepage') }}">
            <img src="{{ asset('images/knowledge_learning_logo.jpeg') }}">
        </a>
    </div>

    <div class="menu-toggle" onclick="toggleMenu()">☰</div>

    <nav class="main-nav">
        {% set route = app.request.attributes.get('_route') %}

        {# Helper pour l'onglet Thèmes actif (themes_ + theme_) #}
        {% set themesActive = (route starts with 'theme_' or route starts with 'themes_') ? 'active' : '' %}

        {# --- ADMIN --- #}
        {% if is_granted('ROLE_ADMIN') %}

            {% set menuItems = [
                {
                    'label':'Accueil',
                    'path': path('homepage'),
                    'active': route == 'homepage' ? 'active' : ''
                },
                {
                    'label':'Dashboard Admin',
                    'path': path('admin_dashboard'),
                    'active': route starts with 'admin_' ? 'active' : '',
                    'submenu': [
                        {'label':'Vue d\'ensemble', 'path': path('admin_dashboard')},
                        {'label':'Clients', 'path': path('admin_users_index')},
                        {'label':'Thèmes', 'path': path('admin_theme_index')},
                        {'label':'Cursus', 'path': path('admin_cursus_index')},
                        {'label':'Leçons', 'path': path('admin_lesson_index')},
                        {'label':'Commandes', 'path': path('admin_purchase_index')},
                        {'label':'Messages contact', 'path': path('admin_contact_index')}
                    ]
                },
                {
                    'label':'Déconnexion',
                    'path': path('app_logout')
                }
            ] %}

        {# --- USER CONNECTÉ (NON ADMIN) --- #}
        {% elseif app.user %}

            {% set userMenu = {
                'label':'Dashboard User',
                'path': path('user_dashboard'),
                'active': route starts with 'user_dashboard' ? 'active' : '',
                'submenu': [
                    {'label':'Vue d\'ensemble', 'path': path('user_dashboard')},
                    {'label':'Modifier profil', 'path': path('user_dashboard_edit')},
                    {'label':'Mot de passe', 'path': path('app_change_password')},
                    {'label':'Mes achats', 'path': path('user_dashboard_purchases')},
                    {'label':'Certifications', 'path': path('user_dashboard_certifications')}
                ]
            } %}

            {# --- Contact --- #}
            {% set contactMenu = {
                'label':'Contact',
                'path': path('contact_index'),
                'active': route starts with 'contact' ? 'active' : ''
            } %}

            {% set menuItems = [
                {
                    'label':'Accueil',
                    'path': path('homepage'),
                    'active': route == 'homepage' ? 'active' : ''
                },
                {
                    'label':'Thèmes',
                    'path': path('themes_index'),
                    'active': themesActive
                },
                {
                    'label':'Panier',
                    'path': path('cart_show'),
                    'active': route starts with 'cart' ? 'active' : '',
                    'count': cartCount
                },
                userMenu,
                contactMenu,
                {
                    'label':'Déconnexion',
                    'path': path('app_logout')
                }
            ] %}

        {# --- VISITEUR --- #}
        {% else %}

            {% set menuItems = [
                {
                    'label':'Accueil',
                    'path': path('homepage'),
                    'active': route == 'homepage' ? 'active' : ''
                },
                {
                    'label':'Thèmes',
                    'path': path('themes_index'),
                    'active': themesActive
                },
                {
                    'label':'S\'inscrire',
                    'path': path('app_register'),
                    'active': route == 'app_register' ? 'active' : ''
                },
                {
                    'label':'Se connecter',
                    'path': path('app_login'),
                    'active': route == 'app_login' ? 'active' : ''
                }
            ] %}

        {% endif %}

        {{ macros.renderMenu(menuItems) }}
    </nav>
</header>

<main>{% block body %}{% endblock %}</main>

<footer>&copy; {{ "now"|date("Y") }} Knowledge Learning - Tous droits réservés</footer>

<script>
  function toggleMenu() {
    document.querySelector('.main-nav > ul')?.classList.toggle('show');
  }

  document.addEventListener('DOMContentLoaded', () => {

    // Sous-menu : clic uniquement en mobile/tablette
    document.querySelectorAll('.has-submenu > a').forEach(link => {
      link.addEventListener('click', (e) => {
        if (window.innerWidth <= 992) {
          e.preventDefault();
          link.parentElement.classList.toggle('open');
        }
      });
    });

    // Auto-suppression des flash
    setTimeout(() => {
      document.querySelectorAll('.flash').forEach(flash => flash.remove());
    }, 4000);
  });
</script>

{% block javascripts %}
{% endblock %}

</body>
</html>