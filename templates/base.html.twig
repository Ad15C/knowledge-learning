<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Plateforme Knowledge Learning{% endblock %}</title>

    <!-- Favicon -->
    <link rel="icon" href="{{ asset('images/knowledge_learning_favicon.png') }}" type="image/x-icon">

    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body>

    <!-- =======================
         Header
    ====================== -->
    <header class="main-header">
        <!-- Logo -->
        <div class="logo">
            <a href="#"><img src="{{ asset('images/knowledge_learning_logo.jpeg') }}" alt="Knowledge Learning Logo"></a>
        </div>

        <!-- Menu -->
        <nav class="main-nav">
            <ul>
                <li><a href="#" class="active">Accueil</a></li>
                <li><a href="#">Thèmes</a></li>
                <li><a href="#">Panier</a></li>
                <li><a href="#">Profil</a></li>
                <li><a href="#">Contact</a></li>
                <li><a href="#">Déconnexion</a></li>
            </ul>
        </nav>
    </header>

    <!-- =======================
         Main Content
    ====================== -->
    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- =======================
         Footer
    ====================== -->
    <footer>
        &copy; {{ "now"|date("Y") }} Knowledge Learning - Tous droits réservés
    </footer>

</body>
</html>
