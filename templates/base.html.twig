{% import 'macros.html.twig' as macros %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Plateforme Knowledge Learning{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Plateforme de formation en ligne Knowledge Learning.{% endblock %}">
    <link rel="canonical" href="{% block canonical_url %}{{ app.request.uri }}{% endblock %}">

    <meta name="robots" content="{% block robots %}index,follow{% endblock %}">

    <link rel="icon" href="{{ asset('images/knowledge_learning_favicon.png') }}" type="image/x-icon">

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
    
    {% block structured_data %}{% endblock %}
</head>
<body>

{% set cartCount = cartCount|default(0) %}

{# Flash messages #}
<div class="flash-messages">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
</div>

{# Header / Menu #}
<header class="main-header">
    <div class="logo">
        <a href="{{ path('homepage') }}">
            <img src="{{ asset('images/knowledge_learning_logo.jpeg') }}">
        </a>
    </div>

    <div class="menu-toggle" id="menuToggle" aria-label="Ouvrir le menu">☰</div>

    <nav class="main-nav">
        {% set route = app.request.attributes.get('_route') %}

        {# Helper pour l'onglet Thèmes actif (themes_ + theme_) #}
        {% set themesActive = (route starts with 'theme_' or route starts with 'themes_') ? 'active' : '' %}

        {# --- ADMIN --- #}
        {% if is_granted('ROLE_ADMIN') %}

            {% set menuItems = [
                {
                    'label':'Accueil',
                    'path': path('homepage'),
                    'active': route == 'homepage' ? 'active' : ''
                },
                {
                    'label':'Mon Espace',
                    'path': path('admin_dashboard'),
                    'active': route starts with 'admin_' ? 'active' : '',
                    'submenu': [
                        {'label':'Vue d\'ensemble', 'path': path('admin_dashboard')},
                        {'label':'Clients', 'path': path('admin_users_index')},
                        {'label':'Thèmes', 'path': path('admin_theme_index')},
                        {'label':'Cursus', 'path': path('admin_cursus_index')},
                        {'label':'Leçons', 'path': path('admin_lesson_index')},
                        {'label':'Commandes', 'path': path('admin_purchase_index')},
                        {'label':'Messages contact', 'path': path('admin_contact_index')}
                    ]
                },
                {
                    'label':'Déconnexion',
                    'path': path('app_logout')
                }
            ] %}

        {# --- USER CONNECTÉ (NON ADMIN) --- #}
        {% elseif app.user %}
            {% set verifyMenu = app.session.get('dev_verify_url') ? {
                'label': 'Vérifier mon compte',
                'path': app.session.get('dev_verify_url')
            } : null %}

            {% set userMenu = {
                'label':'Mon Espace',
                'path': path('user_dashboard'),
                'active': route starts with 'user_dashboard' ? 'active' : '',
                'submenu': [
                    {'label':'Vue d\'ensemble', 'path': path('user_dashboard')},
                    {'label':'Modifier profil', 'path': path('user_dashboard_edit')},
                    {'label':'Mot de passe', 'path': path('app_change_password')},
                    {'label':'Mes achats', 'path': path('user_dashboard_purchases')},
                    {'label':'Certifications', 'path': path('user_dashboard_certifications')}
                ]
            } %}

            {# --- Contact --- #}
            {% set contactMenu = {
                'label':'Contact',
                'path': path('contact_index'),
                'active': route starts with 'contact' ? 'active' : ''
            } %}

            {% set menuItems = [
                {
                    'label':'Accueil',
                    'path': path('homepage'),
                    'active': route == 'homepage' ? 'active' : ''
                },
                {
                    'label':'Thèmes',
                    'path': path('themes_index'),
                    'active': themesActive
                },
                {
                    'label':'Panier',
                    'path': path('cart_show'),
                    'active': route starts with 'cart' ? 'active' : '',
                    'count': cartCount
                },
                 userMenu,
                contactMenu,
                verifyMenu,
                {
                    'label':'Déconnexion',
                    'path': path('app_logout')
                }
            ]|filter(v => v is not null) %}

        {# --- VISITEUR --- #}
        {% else %}
            {% set verifyMenu = app.session.get('dev_verify_url') ? {
                'label': 'Lien de vérification',
                'path': app.session.get('dev_verify_url')
            } : null %}

            {% set menuItems = [
                {
                    'label':'Accueil',
                    'path': path('homepage'),
                    'active': route == 'homepage' ? 'active' : ''
                },
                {
                    'label':'Thèmes',
                    'path': path('themes_index'),
                    'active': themesActive
                },
                {
                    'label':'S\'inscrire',
                    'path': path('app_register'),
                    'active': route == 'app_register' ? 'active' : ''
                },
                {
                    'label':'Se connecter',
                    'path': path('app_login'),
                    'active': route == 'app_login' ? 'active' : ''
                },
                verifyMenu
            ]|filter(v => v is not null) %}

        {% endif %}

        {{ macros.renderMenu(menuItems) }}
    </nav>
</header>

<main>{% block body %}{% endblock %}</main>

<footer>
    &copy; {{ "now"|date("Y") }} Knowledge Learning - Tous droits réservés.
    <br>
    <a href="{{ path('privacy_policy') }}">Politique de confidentialité</a> |
    <a href="{{ path('legal_notice') }}">Mentions légales</a> |
    <a href="{{ path('cookies_policy') }}">Cookies</a> |
    <a href="{{ path('cgv_policy') }}">Conditions générales de vente</a>
</footer>

<script>
window.addEventListener('load', () => {
    const menuToggle = document.getElementById('menuToggle');
    const mainMenu = document.querySelector('.main-nav > ul');
    const submenuParents = document.querySelectorAll('.has-submenu');
    const scrollTopBtn = document.getElementById('scrollTopBtn');

    if (menuToggle && mainMenu) {
        menuToggle.addEventListener('click', () => {
            mainMenu.classList.toggle('show');
        });
    }

    submenuParents.forEach(item => {
        const link = item.querySelector('a');

        if (!link) return;

        link.addEventListener('click', (e) => {
            if (window.innerWidth <= 992 && item.classList.contains('has-submenu')) {
                const submenu = item.querySelector('ul');
                if (!submenu) return;

                if (!item.classList.contains('open')) {
                    e.preventDefault();
                    item.classList.add('open');
                }
            }
        });
    });

    setTimeout(() => {
        document.querySelectorAll('.flash').forEach(flash => flash.remove());
    }, 4000);

    if (scrollTopBtn) {
        window.addEventListener('scroll', () => {
            scrollTopBtn.style.display = window.scrollY > 200 ? 'block' : 'none';
        });

        scrollTopBtn.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    }
});
</script>

{% block javascripts %}{% endblock %}

<button id="scrollTopBtn" title="Retour en haut">
    <img src="{{ asset('images/fleche-32.png') }}" alt="Retour en haut">
</button>
</body>
</html>