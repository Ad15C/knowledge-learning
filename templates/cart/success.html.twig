{% extends 'base.html.twig' %}

{% block title %}Paiement réussi{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/cart-success.css') }}">
{% endblock %}

{% block body %}
<div class="cart-success-wrapper">
    <main class="cart-success">
     <h1>Commande réussie </h1>
        {% for item in purchase.items %}
            <div class="cart-item-card">
                <p class="order-number">Numéro de commande : <strong>{{ purchase.orderNumber }}</strong></p>
                <p class="order-date">Date : {{ purchase.createdAt|date('d/m/Y H:i') }}</p>

                {% if item.lesson %}
                    <div class="cart-item-row">
                        <div class="cart-item-info">
                            <span class="item-badge lesson-badge">Leçon</span>
                            <span class="item-name">{{ item.lesson.title }}</span>
                        </div>
                        <a href="{{ path('lesson_show', {'id': item.lesson.id}) }}" class="cart-link">
                            Accéder <span class="arrow">→</span>
                        </a>
                    </div>
                {% endif %}

                {% if item.cursus %}
                    <div class="cart-item-row">
                        <div class="cart-item-info">
                            <span class="item-badge cursus-badge">Cursus</span>
                            <span class="item-name">{{ item.cursus.name }}</span>
                        </div>
                    </div>
                    {% if item.cursus.lessons|length > 0 %}
                        <ul class="cursus-lessons">
                            {% for lesson in item.cursus.lessons %}
                                <li class="cart-item-row">
                                    <div class="cart-item-info">
                                        <span class="item-badge lesson-badge">Leçon</span>
                                        <span class="item-name">{{ lesson.title }}</span>
                                    </div>
                                    <a href="{{ path('lesson_show', {'id': lesson.id}) }}" class="cart-link">
                                        Accéder <span class="arrow">→</span>
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="no-lessons">Aucune leçon disponible</p>
                    {% endif %}
                {% endif %}
            </div>
        {% endfor %}

        <a href="{{ path('homepage') }}" class="cart-link-back">
            ← Retour à l'accueil
        </a>
    </main>
</div>
{% endblock %}