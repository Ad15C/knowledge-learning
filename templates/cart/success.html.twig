{% extends 'base.html.twig' %}

{% block title %}Paiement réussi{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/user/cart-success.css') }}">
{% endblock %}

{% block body %}
  <div class="cart-success-wrapper">
    <main class="cart-success">

      <h1>Commande réussie</h1>

      <p class="order-number">
        Numéro de commande : <strong>{{ purchase.orderNumber }}</strong>
      </p>

      <p class="order-date">
        Date : {{ purchase.createdAt|date('d/m/Y H:i') }}
      </p>

      {# Badge statut (tu gardes tes helpers) #}
      <p>
        <span class="{{ purchase_status_class(purchase.status) }}">
          {{ purchase_status_label(purchase.status) }}
        </span>
      </p>

      <p class="cart-meta">
        {{ purchase_items_count(purchase) }} produits —
        {{ purchase_items_quantity(purchase) }} articles
      </p>

      {% for item in purchase.items %}
        <div class="cart-success-card">

          {# Leçon achetée seule #}
          {% if item.lesson %}
            <div class="cart-success-row">
              <div class="cart-success-info">
                <span class="item-badge lesson-badge">Leçon</span>
                <span class="item-name">{{ item.lesson.title }}</span>
              </div>

              <a href="{{ path('lesson_show', {'slug': item.lesson.slug}) }}" class="cart-success-link">
                Accéder <span class="arrow">→</span>
              </a>
            </div>
          {% endif %}

          {# Cursus + ses leçons #}
          {% if item.cursus %}
            <div class="cart-success-row">
              <div class="cart-success-info">
                <span class="item-badge cursus-badge">Cursus</span>
                <span class="item-name">{{ item.cursus.name }}</span>
              </div>
            </div>

            {% if item.cursus.lessons is not empty %}
              <ul class="cursus-lessons">
                {% for lesson in item.cursus.lessons %}
                  <li class="cart-success-row">
                    <div class="cart-success-info">
                      <span class="item-badge lesson-badge">Leçon</span>
                      <span class="item-name">{{ lesson.title }}</span>
                    </div>

                    <a href="{{ path('lesson_show', {'slug': lesson.slug}) }}" class="cart-success-link">
                      Accéder <span class="arrow">→</span>
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="no-lessons">Aucune leçon disponible</p>
            {% endif %}
          {% endif %}

        </div>
      {% endfor %}

      <a href="{{ path('homepage') }}" class="back-link">
        ← Retour à l'accueil
      </a>

    </main>
  </div>
{% endblock %}