{% extends 'base.html.twig' %}

{% block title %}{{ cursus.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/themes.css') }}">
{% endblock %}

{% block body %}

<div class="dashboard-layout">

    <main class="dashboard-content">

        <!-- TITRE DU CURSUS -->
        <h1>{{ cursus.name }}</h1>

        {% if cursus.description %}
            <p style="margin-bottom: 30px;">{{ cursus.description }}</p>
        {% endif %}

        <!-- LEÇONS DISPONIBLES -->
        <h2>Leçons disponibles</h2>

        <div class="cursus-grid">
            {% for lesson in cursus.lessons %}
                <div class="cursus-card lesson-card">
                    {% if lesson.image %}
                        <img src="{{ asset(lesson.image) }}" alt="{{ lesson.title }}">
                    {% endif %}

                    <h3>{{ lesson.title }}</h3>
                    <p>Prix : <strong>{{ lesson.price }} €</strong></p>

                    <div style="margin-top: 10px;">
                        {# Bouton ajouter au panier #}
                        <a href="{{ path('cart_add_lesson', {id: lesson.id}) }}" class="btn">
                            Ajouter au panier
                        </a>

                        {# Bouton “Valider la leçon” seulement si l'utilisateur a terminé #}
                        {% if lesson.userHasCompleted %}
                            <a href="{{ path('lesson_validate', {id: lesson.id}) }}" class="btn-secondary">
                                Valider la leçon
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <p>Aucune leçon disponible pour ce cursus.</p>
            {% endfor %}
        </div>
        <a href="{{ path('theme_show', {'id': cursus.theme.id}) }}" class="btn-back">
            ← Retour au thème "{{ cursus.theme.name }}"
        </a>

    </main>

</div>

{% endblock %}
