<div class="form-page-wrapper">
    <div class="form-container">
        <a href="{{ path('user_dashboard') }}" class="btn-back">
            ← Retour au dashboard
        </a>

        <h1>{{ title }}</h1>

        {# Flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form) }}

        {% for child in form %}
            {% set field_type = child.vars.block_prefixes[1] %}
            {% set is_invalid = child.vars.errors|length > 0 %}

            {% if field_type == 'checkbox' %}
                <div class="checkbox-container {% if is_invalid %}is-invalid{% endif %}">
                    {{ form_widget(child) }}
                    {{ form_label(child) }}
                    {% for error in child.vars.errors %}
                        <div class="form-error">{{ error.message }}</div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="form-group {% if is_invalid %}is-invalid{% endif %}">
                    {# Pré-remplir last_username si nécessaire #}
                    {% if child.vars.name == '_username' %}
                        {{ form_widget(child, {'value': last_username|default('')}) }}
                    {% else %}
                        {{ form_widget(child) }}
                    {% endif %}
                    {{ form_label(child) }}
                    {% for error in child.vars.errors %}
                        <div class="form-error">{{ error.message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
        {% endfor %}

        <div style="margin: 15px 0;">
            <button type="submit">{{ button_label }}</button>
        </div>

        {{ form_end(form) }}
    </div>
</div>