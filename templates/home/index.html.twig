{% extends 'base.html.twig' %}

{% block title %}Formation en ligne | Knowledge Learning{% endblock %}

{% block meta_description %}
Découvrez des formations en ligne : développement web, musique, cuisine, jardinage. Apprenez à votre rythme.
{% endblock %}

{# Pages publiques #}
{% block robots %}index,follow{% endblock %}

{% block canonical_url %}
{{ absolute_url(path('homepage')) }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# On réutilise le CSS des thèmes pour avoir les mêmes encadrés #}
    <link rel="stylesheet" href="{{ asset('styles/user/themes.css') }}">
{% endblock %}

{% block body %}
<h1>Bienvenue sur Knowledge Learning</h1>

    <p>Découvrez nos thèmes et formations :</p>

        <div class="themes-grid">
            {% for theme in themes %}
                <article class="theme-card">
                    {% if theme.image %}
                        <img
                            src="{{ asset(theme.image) }}"
                            alt="{{ theme.alt|default(theme.name) }}"
                            class="theme-image"
                        >
                    {% endif %}

                    <h2>{{ theme.name }}</h2>

                    {% if theme.description %}
                        <p>{{ theme.description }}</p>
                    {% endif %}

                    <a href="{{ path('theme_show', {'slug': theme.slug}) }}" class="btn btn-primary">
                        Découvrir
                    </a>
                </article>
            {% else %}
                <p>Aucun thème disponible pour le moment.</p>
            {% endfor %}
        </div>
{% endblock %}
