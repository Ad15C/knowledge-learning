{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/lesson.css') }}">
{% endblock %}

{% block body %}
<div class="lesson-page">
  <h1>{{ lesson.title }}</h1>

  {% if lesson.image %}
    <img src="{{ asset(lesson.image) }}" alt="{{ lesson.title }}" class="lesson-image">
  {% endif %}

  {% if lesson.fiche %}
    {% for paragraph in lesson.fiche|split('<br><br>') %}
      <p>{{ paragraph|raw }}</p>
    {% endfor %}
  {% else %}
    <p>Pas encore de contenu disponible pour cette leçon.</p>
  {% endif %}

  {% set hasAccess = userHasAccess[lesson.id]|default(false) %}
  {% set hasCompleted = userHasCompleted[lesson.id]|default(false) %}

  {% if hasAccess and not hasCompleted %}
    <form method="post"
          action="{{ path('lesson_complete', {id: lesson.id}) }}"
          onsubmit="return confirm('Confirmer que vous avez bien terminé la leçon ?');">
      <input type="hidden" name="_token" value="{{ csrf_token('lesson_complete_' ~ lesson.id) }}">
      <button type="submit" class="btn btn-outline">Marquer comme complétée</button>
    </form>

  {% elseif hasCompleted %}
    <p class="text-success fw-bold">Vous avez déjà complété cette leçon.</p>

    {% if certification %}
      <p class="text-success fw-bold">
        Certificat : <strong>{{ certification.certificateCode }}</strong>
      </p>
      <p>Date : {{ certification.issuedAt|date('d/m/Y') }}</p>

      <a class="btn btn-secondary"
         href="{{ path('app_certification_pdf', {id: certification.id}) }}"
         target="_blank" rel="noopener">
        Télécharger PDF
      </a>
    {% endif %}

  {% else %}
    <p class="text-danger">Vous n'avez pas encore accès à cette leçon.</p>
  {% endif %}

  <div class="mt-3">
    <a href="{{ path('user_dashboard') }}" class="btn btn-secondary">
      ← Retour au tableau de bord
    </a>
  </div>
</div>
{% endblock %}