{% extends 'base.html.twig' %}

{% block title %}{{ cursus.name }}{% endblock %}

{% block body %}
<div class="cursus-page">
  <h1>{{ cursus.name }}</h1>

  {% if cursus.description %}
    <p>{{ cursus.description }}</p>
  {% endif %}

  <h2>Leçons</h2>

  <ul class="lesson-list">
    {% for lesson in cursus.lessons %}
      {% set canAccess = userHasAccess[lesson.id]|default(false) %}

      <li class="lesson-row">
        <div>
          <strong>{{ lesson.title }}</strong>
          {% if not canAccess %}
            <span class="badge badge-locked">Verrouillée</span>
          {% else %}
            <span class="badge badge-unlocked">Accessible</span>
          {% endif %}
        </div>

        <div class="lesson-actions">
          {% if canAccess %}
            <a class="btn btn-outline" href="{{ path('lesson_show', {id: lesson.id}) }}">
              Ouvrir
            </a>

          {% else %}
            {% if app.user %}
              {# connecté mais pas payé : CTA achat #}
              <form method="post" action="{{ path('cart_add_lesson', {id: lesson.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('cart_add_lesson_' ~ lesson.id) }}">
                <button type="submit" class="btn btn-primary">
                  Acheter la leçon ({{ lesson.price }} €)
                </button>
              </form>
            {% else %}
              {# non connecté #}
              <a class="btn btn-primary" href="{{ path('app_login') }}">
                Se connecter pour acheter
              </a>
            {% endif %}
          {% endif %}
        </div>
      </li>
    {% else %}
      <li>Aucune leçon disponible pour ce cursus.</li>
    {% endfor %}
  </ul>

  <div class="mt-3">
    <a href="{{ path('themes_index') }}" class="btn btn-secondary">← Retour aux thèmes</a>
  </div>
</div>
{% endblock %}