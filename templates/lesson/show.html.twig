{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/lesson.css') }}">
{% endblock %}

{% block body %}
<div class="lesson-page">
    <div class="lesson-header">
        <h1>{{ lesson.title }}</h1>

        {% if lesson.cursus %}
            <p class="lesson-meta">
                Cursus :
                <a href="{{ path('cursus_show', { id: lesson.cursus.id }) }}">
                    {{ lesson.cursus.name }}
                </a>
                {% if lesson.cursus.theme %}
                    — Thème : {{ lesson.cursus.theme.name }}
                {% endif %}
            </p>
        {% endif %}
    </div>

    {% set hasAccess = userHasAccess[lesson.id]|default(false) %}
    {% set hasCompleted = userHasCompleted[lesson.id]|default(false) %}

    {% if not hasAccess %}
        <div class="alert alert-danger">
            Vous n’avez pas accès à cette leçon.
        </div>
    {% else %}
        <div class="lesson-content">
            {% if lesson.image %}
                <div class="lesson-cover">
                    <img src="{{ asset(lesson.image) }}" alt="{{ lesson.title }}" class="lesson-image">
                </div>
            {% endif %}

            <div class="lesson-status mb-3">
                {% if hasCompleted %}
                    <span class="badge badge-success">Leçon validée ✔</span>
                {% else %}
                    <span class="badge badge-unlocked">Accès autorisé</span>
                {% endif %}
            </div>

            <section class="lesson-section">
                <h2>Contenu de la leçon</h2>

                {% if lesson.fiche %}
                    <div class="lesson-fiche">
                        {{ lesson.fiche|raw }}
                    </div>
                {% else %}
                    <p>Pas encore de contenu disponible pour cette leçon.</p>
                {% endif %}
            </section>

            {% if lesson.videoUrl %}
                <section class="lesson-section">
                    <h2>Vidéo</h2>
                    <div class="lesson-video">
                        <a href="{{ lesson.videoUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
                            Voir la vidéo
                        </a>
                    </div>
                </section>
            {% endif %}

            <section class="lesson-section lesson-actions-block">
                {% if not hasCompleted %}
                    <form
                        method="post"
                        action="{{ path('lesson_complete', { id: lesson.id }) }}"
                        onsubmit="return confirm('Confirmer que vous avez bien terminé la leçon ?');"
                    >
                        <input type="hidden" name="_token" value="{{ csrf_token('lesson_complete_' ~ lesson.id) }}">
                        <button type="submit" class="btn btn-success">
                            Marquer la leçon comme complétée
                        </button>
                    </form>
                {% else %}
                    <p class="lesson-validated-message">
                        Vous avez déjà complété cette leçon.
                    </p>
                {% endif %}
            </section>

            {% if certification %}
                <section class="lesson-section certification-block">
                    <h2>Certification</h2>
                    <p>Une certification a été générée pour cette leçon.</p>
                    <p><strong>Code :</strong> {{ certification.certificateCode }}</p>

                    {% if certification.issuedAt %}
                        <p><strong>Délivrée le :</strong> {{ certification.issuedAt|date('d/m/Y H:i') }}</p>
                    {% endif %}

                    {% if certification.id is defined %}
                        <a
                            class="btn btn-secondary"
                            href="{{ path('app_certification_pdf', { id: certification.id }) }}"
                            target="_blank"
                            rel="noopener"
                        >
                            Télécharger le PDF
                        </a>
                    {% endif %}
                </section>
            {% endif %}
        </div>
    {% endif %}

    <div class="mt-4">
        {% if lesson.cursus %}
            <a href="{{ path('cursus_show', { id: lesson.cursus.id }) }}" class="btn btn-secondary">
                ← Retour au cursus
            </a>
        {% else %}
            <a href="{{ path('themes_index') }}" class="btn btn-secondary">
                ← Retour aux thèmes
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}