{% extends 'base.html.twig' %}

{% block title %}Leçon Validée{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/lesson_validated.css') }}">
{% endblock %}

{% block body %}
<div class="lesson-validated-container">
    <div class="lesson-validated-card">
        <h1>🎉 Bravo {{ app.user.firstName ?? app.user.username }} !</h1>

        {% if lessonValidated.lesson %}
            <p>Vous avez terminé la leçon : <strong>{{ lessonValidated.lesson.title }}</strong> ✅</p>

            {% set theme = lessonValidated.lesson.theme %}
            {% if theme %}
                {% set totalLessons = theme.lessons|length %}
                {% set completedLessons = lessonValidated.user.lessonValidated|filter(lv => lv.lesson.theme.id == theme.id)|length %}
                {% set progressPercent = (completedLessons / totalLessons * 100)|round(0, 'floor') %}

                <!-- Cercle de progression -->
                <div class="progress-circle" data-progress="{{ progressPercent }}">
                    <span>{{ progressPercent }}%</span>
                    <svg>
                        <circle class="bg" r="50" cx="60" cy="60"></circle>
                        <circle class="progress" r="50" cx="60" cy="60"></circle>
                    </svg>
                </div>
                <p class="progress-text">{{ completedLessons }}/{{ totalLessons }} leçons terminées</p>

                {% if allCompleted %}
                    <p>🎓 Félicitations ! Vous avez complété le thème : 
                        <strong>{{ theme.title }}</strong> et obtenu votre certification.</p>
                {% else %}
                    <p>📚 Continuez à valider les leçons pour compléter le thème et obtenir votre certification.</p>
                {% endif %}

                {% if theme.cursus %}
                    <a href="{{ path('lesson_list', {'cursusId': theme.cursus.id}) }}" class="btn btn-primary">
                        Retour aux leçons
                    </a>
                {% else %}
                    <p>⚠️ Cursus introuvable pour ce thème.</p>
                    <a href="{{ path('user_dashboard') }}" class="btn btn-secondary">
                        Retour au tableau de bord
                    </a>
                {% endif %}
            {% else %}
                <p>⚠️ Thème introuvable pour cette leçon.</p>
                <a href="{{ path('user_dashboard') }}" class="btn btn-secondary">
                    Retour au tableau de bord
                </a>
            {% endif %}

        {% else %}
            <p>⚠️ Leçon introuvable.</p>
            <a href="{{ path('user_dashboard') }}" class="btn btn-secondary">
                Retour au tableau de bord
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.querySelectorAll('.progress-circle').forEach(circle => {
    const progress = circle.dataset.progress;
    const circleProgress = circle.querySelector('.progress');
    const radius = circleProgress.r.baseVal.value;
    const circumference = 2 * Math.PI * radius;

    circleProgress.style.strokeDasharray = `${circumference} ${circumference}`;
    circleProgress.style.strokeDashoffset = circumference;

    const offset = circumference - (progress / 100) * circumference;
    setTimeout(() => {
        circleProgress.style.strokeDashoffset = offset;
    }, 200);
});
</script>
{% endblock %}
