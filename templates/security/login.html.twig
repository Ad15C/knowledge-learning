{% extends 'base.html.twig' %}

{% block title %}Connexion - Knowledge Learning{% endblock %}

{% block body %}
{# Ajouter le CSS spécifique à cette page #}
<link rel="stylesheet" href="{{ asset('styles/login.css') }}">

<main class="login-page">
    <div class="login-container">
        <form method="post" action="{{ path('app_login') }}">
            <h1>Connexion</h1>

            {% if error %}
                <div class="flash flash-error">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <input type="email" name="_username"
                   value="{{ last_username|default('') }}"
                   placeholder="Email"
                   required
                   autocomplete="username">

            <input type="password" name="_password"
                   placeholder="Mot de passe"
                   required
                   autocomplete="current-password">

            {# CSRF token #}
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <label>
                <input type="checkbox" name="_remember_me">
                Se souvenir de moi
            </label>

            <div style="margin: 15px 0;">
                {% set button_label = 'Se connecter' %}
                <button type="submit" id="login-submit">Se connecter</button>
            </div>
        </form>
       <a href="{{ path('homepage') }}" class="btn-back">← Retour à l'accueil</a>
    </div>
</main>
{% endblock %}
