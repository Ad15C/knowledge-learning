{% extends 'base.html.twig' %}

{% block title %}Thèmes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user-shared.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/themes.css') }}">
{% endblock %}

{% block body %}
<h1>Liste des Thèmes</h1>

<form id="filter-form" method="get" class="dashboard-filters" autocomplete="off">
    <label>
        <span>Nom du thème</span>
        <input type="search" name="name" placeholder="Ex : Nutrition" value="{{ filter_name|default('') }}">
    </label>

    <label>
        <span>Prix minimum</span>
        <input type="number" step="0.01" min="0" name="minPrice" placeholder="0.00" value="{{ filter_minPrice|default('') }}">
    </label>

    <label>
        <span>Prix maximum</span>
        <input type="number" step="0.01" min="0" name="maxPrice" placeholder="0.00" value="{{ filter_maxPrice|default('') }}">
    </label>

    <div class="filter-actions">
        <button type="submit">Filtrer</button>
        <a href="{{ path('themes_index') }}" class="btn">Réinitialiser</a>
    </div>
</form>

<div id="themes-list">
    {% include 'themes/_themes_list.html.twig' with {'themes': themes} %}
</div>

<a href="{{ path('homepage') }}" class="btn-back">← Retour à l'accueil</a>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
    const form = document.getElementById('filter-form');
    const list = document.getElementById('themes-list');
    if (!form || !list) return;

    form.addEventListener('submit', function (e) {
        e.preventDefault();

        const formData = new FormData(form);
        const params = new URLSearchParams(formData).toString();

        fetch('{{ path('themes_index') }}?' + params, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.text())
        .then(html => {
            list.innerHTML = html;
        });
    });
})();
</script>
{% endblock %}