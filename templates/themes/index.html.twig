{% extends 'base.html.twig' %}

{% block title %}Thèmes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/css/themes.css') }}">
{% endblock %}

{% block body %}
<h1>Nos Thèmes</h1>

<div class="themes-grid">
    {% for theme in themes %}
        <div class="theme-card">
            {% if theme.image %}
                <img src="{{ asset(theme.image) }}" alt="{{ theme.name }}" class="theme-image">
            {% endif %}

            <h2>{{ theme.name }}</h2>

            {% if theme.description %}
                <p>{{ theme.description }}</p>
            {% endif %}

            <a href="{{ path('theme_show', {'id': theme.id}) }}" class="btn btn-primary">
                Découvrir
            </a>
        </div>
    {% else %}
        <p>Aucun thème disponible.</p>
    {% endfor %}
</div>
<a href="{{ path('homepage') }}" class="btn-back">← Retour à l'accueil</a>
{% endblock %}