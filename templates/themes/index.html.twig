{% extends 'base.html.twig' %}

{% block title %}Thèmes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/css/themes.css') }}">
{% endblock %}

{% block body %}
<h1>Liste des Thèmes</h1>

<form id="filter-form" class="filter-form">
    <input type="text" name="name" placeholder="Nom du thème" value="{{ filter_name|default('') }}">

    <input type="number" step="0.01" name="minPrice" placeholder="Prix min"
           value="{{ filter_minPrice|default('') }}">

    <input type="number" step="0.01" name="maxPrice" placeholder="Prix max"
           value="{{ filter_maxPrice|default('') }}">

    <button type="submit">Filtrer</button>
</form>

<div id="themes-list">
    {% include 'themes/_themes_list.html.twig' with {'themes': themes} %}
</div>

<a href="{{ path('homepage') }}" class="btn-back">← Retour à l'accueil</a>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
    const form = document.getElementById('filter-form');
    const list = document.getElementById('themes-list');
    if (!form || !list) return;

    form.addEventListener('submit', function (e) {
        e.preventDefault();

        const formData = new FormData(form);
        const params = new URLSearchParams(formData).toString();

        fetch('{{ path('themes_index') }}?' + params, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.text())
        .then(html => {
            list.innerHTML = html;
        });
    });
})();
</script>
{% endblock %}