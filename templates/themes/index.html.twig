{% extends 'base.html.twig' %}

{% block title %}Tous les thèmes de formation | Knowledge Learning{% endblock %}

{% block meta_description %}
Explorez nos thèmes de formation en ligne : musique, informatique, cuisine, jardinage.
{% endblock %}

{% block canonical_url %}
{{ absolute_url(path('themes_index')) }}
{% endblock %}

{% block robots %}index,follow{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user-shared.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/user/themes.css') }}">
{% endblock %}

{% block body %}
<h1>Tous les thèmes de formation</h1>

    <p>
    Découvrez nos thèmes de formation en ligne et trouvez le cursus qui correspond à vos objectifs.
    </p>

    <form id="filter-form" method="get" class="dashboard-filters" autocomplete="off">
        <label for="name">
            <span>Nom du thème :</span>
            <input type="search" name="name" id="name" placeholder="Ex : Nutrition" value="{{ filter_name|default('') }}">
        </label>

        <label for="minPrice">
            <span>Prix minimum :</span>
            <input type="number" step="0.01" min="0" name="minPrice" id="minPrice" placeholder="0.00" value="{{ filter_minPrice|default('') }}">
        </label>

        <label for="maxPrice">
            <span>Prix maximum :</span>
            <input type="number" step="0.01" min="0" name="maxPrice" id="maxPrice" placeholder="0.00" value="{{ filter_maxPrice|default('') }}">
        </label>

        <div class="filter-actions">
            <button type="submit">Filtrer</button>
            <a href="{{ path('themes_index') }}" class="btn">Réinitialiser</a>
        </div>
    </form>

    <div id="themes-list">
        {% include 'themes/_themes_list.html.twig' with {'themes': themes} %}
    </div>

    <a href="{{ path('homepage') }}" class="back-link">← Retour à l'accueil</a>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
    const form = document.getElementById('filter-form');
    const list = document.getElementById('themes-list');
    if (!form || !list) return;

    form.addEventListener('submit', function (e) {
        e.preventDefault();

        const formData = new FormData(form);
        const params = new URLSearchParams(formData).toString();

        fetch('{{ path('themes_index') }}?' + params, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.text())
        .then(html => {
            list.innerHTML = html;
        });
    });
})();
</script>
{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Tous les thèmes de formation",
  "url": "{{ absolute_url(path('themes_index')) }}"
}
</script>
{% endblock %}