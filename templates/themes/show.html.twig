<div class="theme-item">
    {% if theme.image %}
        <img src="{{ asset('uploads/themes/' ~ theme.image) }}" alt="{{ theme.name }}">
    {% endif %}
    <h2>{{ theme.name }}</h2>
    {% for cursus in theme.cursus %}
        <div class="cursus-item">
            {% if cursus.image %}
                <img src="{{ asset('uploads/cursus/' ~ cursus.image) }}" alt="{{ cursus.name }}">
            {% endif %}
            <strong>{{ cursus.name }} - {{ cursus.price }} €</strong>
            <ul>
                {% for lesson in cursus.lessons %}
                    <li>
                        {% if lesson.image %}
                            <img src="{{ asset('uploads/lessons/' ~ lesson.image) }}" alt="{{ lesson.title }}">
                        {% endif %}
                        {{ lesson.title }} - {{ lesson.price }} €
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endfor %}
</div>
