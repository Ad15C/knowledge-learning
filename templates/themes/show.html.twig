{% extends 'base.html.twig' %}

{% block title %}{{ theme.name }} | Knowledge Learning {% endblock %}

{% block meta_description %}
Découvrez le thème {{ theme.name }} sur Knowledge Learning et explorez ses cursus disponibles.
{% endblock %}

{# Pages publiques #}
{% block robots %}index,follow{% endblock %}

{% block canonical_url %}
    {{ absolute_url(path('theme_show', { slug: theme.slug })) }}
{% endblock %}


{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/user/themes.css') }}">
{% endblock %}

{% block body %}
<div class="dashboard-layout">
  <main class="dashboard-content">

    <h1>{{ theme.name }}</h1>

      {% if theme.description %}
        <p style="margin-bottom: 30px;">{{ theme.description }}</p>
      {% endif %}

      <h2>Cursus disponibles</h2>

      <div class="cursus-grid">
        {% for cursus in theme.cursus %}
          <div class="cursus-card">

            {% if cursus.image %}
              <img 
                src="{{ asset(cursus.image) }}" 
                alt="Cursus {{ cursus.name }}"
                loading="lazy"
              >
            {% endif %}

            <h3>{{ cursus.name }}</h3>
              <p>Prix : <strong>{{ cursus.price }} €</strong></p>

              <div style="margin-top: 10px;">
                <a href="{{ path('cursus_show', { slug: cursus.slug }) }}" class="btn-secondary">
                  Détails du cursus
                </a>

                <form method="post" action="{{ path('cart_add_cursus', { slug: cursus.slug }) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('cart_add_cursus_' ~ cursus.slug) }}">
                    <button type="submit" class="btn">Ajouter au panier</button>
                </form>
              </div>
          </div>
        {% else %}
          <p>Aucun cursus disponible pour ce thème.</p>
        {% endfor %}
      </div>

      <a href="{{ path('themes_index') }}" class="back-link">← Retour aux Thèmes</a>

  </main>
</div>
{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "{{ absolute_url(path('homepage')) }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Thèmes",
      "item": "{{ absolute_url(path('themes_index')) }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ theme.name|e('js') }}",
      "item": "{{ absolute_url(path('theme_show', { slug: theme.slug })) }}"
    }
  ]
}
</script>
{% endblock %}