{% extends 'dashboard/user/_base.html.twig' %}

{% block title %}Certificat officiel{% endblock %}

{# Pages privées #}
{% block robots %}noindex,nofollow{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/user/certification-common.css') }}">
  <link rel="stylesheet" href="{{ asset('styles/user/certification-show.css') }}">
  <link rel="stylesheet" href="{{ asset('styles/user/certification.css') }}">
{% endblock %}

{% block dashboard_content %}

  {% if certification %}

    <div class="certification-wrapper">
      <div class="certificate-official">

        <!-- Header -->
        <div class="certificate-header">
          <h1>CERTIFICAT OFFICIEL</h1>
            <p class="certificate-org">Knowledge Learning</p>
        </div>

        <!-- Body -->
        <div class="certificate-body">
          <p class="certificate-label">Ce certificat est décerné à</p>

          <p class="certificate-user">{{ certification.user.firstName }} {{ certification.user.lastName }}</p>

          <p class="certificate-label">pour la réussite du programme</p>

          <p class="certificate-course">
            {% if certification.cursus %}
              {{ certification.cursus.name }}
            {% elseif certification.lesson %}
              {{ certification.lesson.title }}
            {% elseif certification.theme %}
              {{ certification.theme.name }}
            {% endif %}
          </p>

          <p class="certificate-date">
            Délivré le {{ certification.issuedAt|date('d/m/Y') }}
          </p>

          <p class="certificate-code">
            Certificat n° {{ certification.certificateCode }}
          </p>
        </div>

        <!-- Footer -->
        <div class="certificate-footer">
          <div class="certificate-signature">
            <div class="signature-line"></div>
            <p>Directeur de la formation</p>
          </div>

          <div class="certificate-seal">
            OFFICIEL
          </div>
        </div>

      </div>
    </div>

    <!-- Boutons -->
    <div class="certificate-actions">
      <button onclick="window.print()" class="btn btn-primary">🖨 Imprimer</button>

      <a class="btn btn-secondary"
         href="{{ path('app_certification_pdf', {id: certification.id}) }}"
         target="_blank">
        Télécharger le PDF
      </a>

      <a href="{{ path('user_dashboard_certifications') }}" class="btn btn-secondary">
        ← Retour à mes certificats
      </a>
    </div>

  {% else %}
    <p>Certification introuvable.</p>
  {% endif %}

{% endblock %}