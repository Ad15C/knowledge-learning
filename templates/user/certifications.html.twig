{% extends 'dashboard/user/_base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/user/certification-common.css') }}">
  <link rel="stylesheet" href="{{ asset('styles/user/certification.css') }}">
{% endblock %}

{% block title %}Mes certificats{% endblock %}

{# Pages privées #}
{% block robots %}noindex,nofollow{% endblock %}

{% block dashboard_content %}

  <h1>Mes certificats</h1>

  <form method="get" class="dashboard-filters" autocomplete="off">
    <label for="cursus">Cursus :</label>
      <select name="cursus" id="cursus">
        <option value="">Tous</option>
        {% for cursus in all_cursus %}
          <option value="{{ cursus.id }}" {% if filter_cursus == cursus.id %}selected{% endif %}>
            {{ cursus.name }}
          </option>
        {% endfor %}
      </select>

    <label for="from">Du :</label>
    <input type="date" name="from" id="from" value="{{ filter_from|default('') }}">

    <label for="to">Au :</label>
    <input type="date" name="to" id="to" value="{{ filter_to|default('') }}">

    <button type="submit" class="btn">Filtrer</button>
  </form>

  {% if certifications is empty %}
    <p>Vous n’avez aucun certificat pour le moment.</p>
  {% else %}
    <div class="dashboard-cards">
      {% for cert in certifications %}
        <div class="dashboard-card card-white">
          <h2>
            {% if cert.lesson %}
              Leçon : {{ cert.lesson.title }}
            {% elseif cert.cursus %}
              Cursus : {{ cert.cursus.name }}
            {% elseif cert.theme %}
              Thème : {{ cert.theme.name }}
            {% else %}
              Certificat
            {% endif %}
          </h2>

          <p>Code : <strong>{{ cert.certificateCode }}</strong></p>
          <p>Délivré le : {{ cert.issuedAt|date('d/m/Y') }}</p>

          <a href="{{ path('certification_show', {'id': cert.id}) }}" class="card-link-detail">
            Voir le certificat →
          </a>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <a href="{{ path('user_dashboard') }}" class="back-link">← Retour à l'espace membre</a>

{% endblock %}