{% extends 'base.html.twig' %}

{% block title %}Mes Certifications{% endblock %}

{% block body %}

<div class="dashboard-layout">

    <!-- SIDEBAR -->
    <aside class="dashboard-sidebar">
        <div class="sidebar-header">Espace membre</div>
        <nav class="sidebar-nav">
            <a href="{{ path('user_dashboard') }}" class="sidebar-link">Dashboard</a>
            <a href="{{ path('user_dashboard_edit') }}" class="sidebar-link">Modifier profil</a>
            <a href="{{ path('user_dashboard_password') }}" class="sidebar-link">Mot de passe</a>
            <a href="{{ path('user_dashboard_purchases') }}" class="sidebar-link">Mes commandes</a>
            <a href="{{ path('user_dashboard_certifications') }}" class="sidebar-link active">Mes certifications</a>
        </nav>
    </aside>

    <!-- CONTENU -->
    <div class="dashboard-content">
        <h1>Mes Certifications</h1>

        <!-- FILTRES -->
        <form method="get" class="dashboard-filters">
            <label for="cursus">Cursus :</label>
            <select name="cursus" id="cursus">
                <option value="">Tous</option>
                {% for cursus in all_cursus %}
                    <option value="{{ cursus.id }}" {% if filter_cursus == cursus.id %}selected{% endif %}>
                        {{ cursus.name }}
                    </option>
                {% endfor %}
            </select>

            <label for="from">De :</label>
            <input type="date" name="from" id="from" value="{{ filter_from|default('') }}">

            <label for="to">À :</label>
            <input type="date" name="to" id="to" value="{{ filter_to|default('') }}">

            <button type="submit">Filtrer</button>
        </form>

        {% if certifications is empty %}
            <p>Vous n'avez aucune certification pour le moment.</p>
        {% else %}
            <div class="dashboard-cards">
                {% for cert in certifications %}
                    <div class="dashboard-card">
                        <h2>{{ cert.cursus.name }}</h2>
                        <p>
                            Code du certificat : <strong>{{ cert.certificateCode }}</strong>
                        </p>
                        <p>
                            Date : {{ cert.issuedAt|date('d/m/Y') }}
                        </p>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <a href="{{ path('user_dashboard') }}" class="btn-back">
            ← Retour au dashboard
        </a>
    </div>
</div>

{% endblock %}
