{% extends 'dashboard/user/_base.html.twig' %}

{% block title %}Changer mon mot de passe{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('styles/form.css') }}">
{% endblock %}

{% block dashboard_content %}

  {% set title = 'Changer mon mot de passe' %}
  {% set back_path = path('user_dashboard') %}
  {% set button_label = 'Modifier le mot de passe' %}
  {% set button_id = 'change-password-submit' %}

  {% include 'form/_form_container.html.twig' with {
    title: title,
    form: passwordForm,
    back_path: back_path,
    button_label: button_label,
    button_id: button_id
  } %}

{% endblock %}