{% extends 'base.html.twig' %}

{% block title %}Changer mon mot de passe{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/form.css') }}">
{% endblock %}

{% block body %}
    {% set title = 'Changer mon mot de passe' %}
    {% set form = passwordForm %}
    {% set button_label = 'Modifier le mot de passe' %}
    {% set button_id = 'change-password-submit' %}
    {% set back_path = path('user_dashboard') %}

    {# Inclut le formulaire avec le container générique #}
    <div class="form-page-wrapper">
        <div class="form-container">
            {% if back_path is defined %}
                <a href="{{ back_path }}" class="btn-back">← Retour</a>
            {% endif %}

            {% if title is defined %}
                <h1>{{ title }}</h1>
            {% endif %}

            {# Flash messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {{ form_start(form) }}

            {% for child in form %}
                {% set field_type = child.vars.block_prefixes[1] %}
                {% set is_invalid = child.vars.errors|length > 0 %}

                {% if child.vars.name == 'plainPassword' %}
                    {# Gestion spéciale du RepeatedType #}
                    <div class="form-group {% if is_invalid %}is-invalid{% endif %}">
                        {{ form_label(child.first) }}
                        {{ form_widget(child.first) }}
                        {% for error in child.first.vars.errors %}
                            <div class="form-error">{{ error.message }}</div>
                        {% endfor %}

                        {{ form_label(child.second) }}
                        {{ form_widget(child.second) }}
                        {% for error in child.second.vars.errors %}
                            <div class="form-error">{{ error.message }}</div>
                        {% endfor %}

                        {% for error in child.vars.errors %}
                            <div class="form-error">{{ error.message }}</div>
                        {% endfor %}
                    </div>
                {% elseif field_type == 'checkbox' %}
                    <div class="checkbox-container {% if is_invalid %}is-invalid{% endif %}">
                        {{ form_widget(child) }}
                        {{ form_label(child) }}
                        {% for error in child.vars.errors %}
                            <div class="form-error">{{ error.message }}</div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="form-group {% if is_invalid %}is-invalid{% endif %}">
                        {{ form_widget(child) }}
                        {{ form_label(child) }}
                        {% for error in child.vars.errors %}
                            <div class="form-error">{{ error.message }}</div>
                        {% endfor %}
                    </div>
                {% endif %}
            {% endfor %}

            {# Bouton submit #}
            {% if button_label is defined %}
                <div style="margin: 15px 0;">
                    <button type="submit" id="{{ button_id|default('form-submit') }}">{{ button_label }}</button>
                </div>
            {% endif %}

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}