{% extends 'base.html.twig' %}

{% block title %}Mon Dashboard{% endblock %}

{% block body %}
<h1>Bienvenue, {{ user.firstname }} {{ user.lastname }} !</h1>

<nav class="dashboard-nav">
    <ul>
        <li><a href="{{ path('user_dashboard') }}">Vue d'ensemble</a></li>
        <li><a href="{{ path('user_dashboard_edit') }}">Modifier profil</a></li>
        <li><a href="{{ path('user_dashboard_password') }}">Mot de passe</a></li>
        <li><a href="{{ path('user_dashboard_purchases') }}">Mes achats</a></li>
        <li><a href="{{ path('user_dashboard_certifications') }}">Certifications</a></li>
    </ul>
</nav>

<div class="dashboard-container">

    <!-- Header / Progression -->
    <div class="dashboard-header">
        <div>
            <h2>Bonjour {{ user.firstname }} !</h2>
            <p class="subtitle">Bienvenue sur votre dashboard</p>
        </div>

        <div class="progress-card">
            <div class="progress-title">
                Statut actuel : {{ status }}
            </div>
            <div class="progress-subtitle">
                Progression vers {{ nextStatus }} : {{ progressPercent }}%
            </div>
            <div class="progress-bar">
                <div class="progress-fill {{ status|lower }}" style="width: {{ progressPercent }}%"></div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">{{ totalOrders }}</div>
            <div class="stat-label">Commandes</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">{{ totalSpent }} €</div>
            <div class="stat-label">Total dépensé</div>
        </div>
    </div>

    <!-- Derniers achats -->
    <div class="dashboard-card">
        <div class="card-header">
            <h2>Derniers achats</h2>
        </div>

        {% if orders is empty %}
            <p>Aucun achat pour le moment.</p>
        {% else %}
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Date</th>
                        <th>Montant</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>#{{ order.id }}</td>
                            <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ order.total }} €</td>
                            <td>
                                <span class="status status-{{ order.status|lower }}">{{ order.status }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

</div>
{% endblock %}
