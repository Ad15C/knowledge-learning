{% extends 'base.html.twig' %}

{% block body %}

<div class="dashboard-layout">

    <!-- SIDEBAR -->
    <aside class="dashboard-sidebar">

        <div class="sidebar-header">
            Espace membre
        </div>

        <nav class="sidebar-nav">

            <a href="{{ path('user_dashboard') }}" class="sidebar-link active">
                Dashboard
            </a>

            <a href="{{ path('user_dashboard_edit') }}" class="sidebar-link">
                Modifier profil
            </a>

            <a href="{{ path('user_dashboard_password') }}" class="sidebar-link">
                Mot de passe
            </a>

            <a href="{{ path('user_dashboard_purchases') }}" class="sidebar-link">
                Mes commandes
            </a>

            <a href="{{ path('user_dashboard_certifications') }}" class="sidebar-link">
                Mes certifications
            </a>

        </nav>

    </aside>


    <!-- MAIN CONTENT -->
    <main class="dashboard-main">

        <h1>
            Bienvenue, {{ app.user.firstname }} {{ app.user.lastname }}
        </h1>


        <div class="dashboard-sections">

            <!-- STATUT -->
            <div class="dashboard-card">

                <h2>Mon statut et progression</h2>

                <p>
                    Statut actuel :
                    <strong>{{ status }}</strong>
                </p>

                <div class="progress-bar">
                    <div class="progress-fill"
                         style="width: {{ progressPercent }}%">
                    </div>
                </div>

                <small>
                    {{ progressPercent }}% vers {{ nextStatus }}
                </small>

            </div>



            <!-- COMMANDES -->
            <a href="{{ path('user_dashboard_purchases') }}"
               class="dashboard-card dashboard-card-clickable">

                <h2>Mes commandes</h2>

                <p>
                    Total commandes :
                    <strong>{{ totalOrders }}</strong>
                </p>

                <p>
                    Total dépensé :
                    <strong>{{ totalSpent }} €</strong>
                </p>

                <span class="card-link-indicator">
                    Voir mes commandes →
                </span>

            </a>



            <!-- CERTIFICATIONS -->
            <a href="{{ path('user_dashboard_certifications') }}"
               class="dashboard-card dashboard-card-clickable">

                <h2>Mes certifications</h2>

                <p>
                    Certifications obtenues :
                    <strong>{{ certificationsCount|default(0) }}</strong>
                </p>

                <span class="card-link-indicator">
                    Voir mes certifications →
                </span>

            </a>

        </div>

    </main>

</div>

{% endblock %}
