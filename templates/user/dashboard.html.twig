{% extends 'base.html.twig' %}

{% block title %}Mon Dashboard{% endblock %}

{% block body %}
<div class="dashboard-container">

    <!-- Header -->
    <div class="dashboard-header" style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:20px;">
        <div>
            <h1>Bonjour {{ app.user.firstname }}</h1>
            <p class="subtitle">Bienvenue sur votre dashboard</p>
        </div>

        <!-- Progression / Statut -->
        <div class="progress-card">
            <div class="progress-title">
                Statut : {{ status }}
            </div>
            <div class="progress-subtitle">
                Progression vers {{ nextStatus }} : {{ progressPercent }}%
            </div>
            <div class="progress-bar">
                <div class="progress-fill {{ status|lower }}" style="width: {{ progressPercent }}%"></div>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div>
                <div class="stat-value">{{ totalOrders }}</div>
                <div class="stat-label">Commandes</div>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <div class="stat-value">{{ totalSpent }} €</div>
                <div class="stat-label">Total dépensé</div>
            </div>
        </div>
    </div>

    <!-- Derniers achats -->
    <div class="dashboard-card">
        <div class="card-header">
            <h2>Derniers achats</h2>
        </div>

        {% if orders|length > 0 %}
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Date</th>
                        <th>Montant</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>#{{ order.id }}</td>
                            <td>{{ order.createdAt|date('d/m/Y') }}</td>
                            <td>{{ order.total }} €</td>
                            <td>
                                <span class="status status-{{ order.status }}">{{ order.status }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>Aucun achat pour le moment.</p>
        {% endif %}
    </div>

</div>
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
{% endblock %}

